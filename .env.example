# ─── Environment Variables Template ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# .env is listed in .gitignore by default.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=inventorydb

# ── Backend ───────────────────────────────────────────────────────────────────
# Full connection string (auto-constructed by docker-compose from vars above)
# DATABASE_URL=postgresql://postgres:your_strong_password_here@db:5432/inventorydb

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL where the browser (not Docker) reaches the backend API
# In local Docker: http://localhost:8000
# In production:   https://your-backend.render.com  (or railway, fly.io)
REACT_APP_API_URL=http://localhost:8000
