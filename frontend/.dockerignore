# ── Dependencies (reinstalled inside the image) ───────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output (generated inside the image) ─────────────────────────────────
build/

# ── Environment files (never bake secrets into the image) ─────────────────────
.env
.env.*
!.env.example

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
