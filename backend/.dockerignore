# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment files (never copy secrets into the image) ────────────────────
.env
.env.*
!.env.example

# ── IDE / editor files ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# ── Git ───────────────────────────────────────────────────────────────────────
.git/
.gitignore
